{
    "name": "retroflightsim",
    "description": "Simulating early 90s flight sim visuals",
    "version": "0.0.1",
    "scripts": {
        "pack-mods": "python tools/pack_aircraft_mods.py",
        "build": "webpack --mode=development && npm run pack-mods",
        "build:prod": "webpack --mode=production && npm run pack-mods",
        "start": "node tools/dev.mjs",
        "watch": "node tools/watch.mjs",
        "preserve": "npm run build",
        "serve": "tsx tools/modserver.ts",
        "test": "node --import tsx --test src/script/physics/**/*.test.ts src/script/ai/**/*.test.ts",
        "postinstall": "patch-package"
    },
    "author": "Ruben Moreno Montoliu <ruben3d@gmail.com>",
    "license": "MIT",
    "homepage": "https://github.com/ruben3d/retroflightsim",
    "dependencies": {
        "@0x62/jsbsim-wasm": "^1.2.4-beta.4",
        "fflate": "~0.8.2",
        "three": "0.185.1"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/multer": "^2.2.0",
        "@types/three": "0.185.0",
        "copy-webpack-plugin": "~14.0.0",
        "express": "^5.2.1",
        "local-web-server": "~5.4.0",
        "multer": "^2.2.0",
        "patch-package": "^8.0.1",
        "ts-loader": "~9.6.2",
        "tsx": "^4.23.0",
        "typescript": "~6.0.3",
        "webpack": "~5.108.4",
        "webpack-cli": "~7.2.1"
    }
}
