{
    "compilerOptions": {
        "module": "esnext",
        "moduleResolution": "bundler",
        "ignoreDeprecations": "6.0",
        "rootDir": "./src",
        "target": "ES6",
        "lib": [
            "dom",
            "es2019"
        ],
        "outDir": "./dist/",
        "sourceMap": true,
        "strict": true,
        "removeComments": true,
        "preserveConstEnums": true
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "src/**/*.test.ts"
    ]
}